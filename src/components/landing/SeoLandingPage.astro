---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../Disclaimer.astro';
import FaqAccordion from '../FaqAccordion.astro';
import SectionHeading from '../SectionHeading.astro';
import LandingRelatedLinks from './LandingRelatedLinks.astro';
import type { LandingPageData } from '../../data/landingPages';
import { faqJsonLd, webPageJsonLd } from '../../lib/seo';

interface Props {
  page: LandingPageData;
}
const { page } = Astro.props;
---

<BaseLayout
  title={page.title}
  description={page.description}
  path={page.path}
  jsonLd={[webPageJsonLd(page.title, page.description, page.path), faqJsonLd(page.faq)]}
>
  <article>
    <header class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
      <div class="section-pad mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">{page.eyebrow}</p>
        <h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
          {page.h1}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
          {page.intro}
        </p>
        <a href="/test" class="btn-primary mt-8 !inline-flex">
          {page.ctaLabel}
        </a>
        <p class="mt-4 text-xs text-slate-500 dark:text-slate-500">25 questions · Instant illustrative results · No email required</p>
      </div>
    </header>

    <div class="section-pad mx-auto max-w-3xl">
      <div class="space-y-12 [&_a]:font-semibold [&_a]:text-brand-600 [&_a]:underline-offset-2 hover:[&_a]:underline dark:[&_a]:text-brand-400">
        {page.sections.map((section) => (
          <section>
            <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white">{section.heading}</h2>
            {section.paragraphs.map((p) => (
              <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
            ))}
          </section>
        ))}
      </div>

      <Disclaimer />

      <section class="mt-14" aria-labelledby={`faq-${page.slug}`}>
        <SectionHeading
          eyebrow="FAQ"
          title={page.faqTitle}
          align="center"
        />
        <h2 id={`faq-${page.slug}`} class="sr-only">{page.faqTitle}</h2>
        <div class="mt-10">
          <FaqAccordion items={page.faq} />
        </div>
      </section>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2 rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 p-8 text-center text-white lg:p-10">
          <h2 class="font-display text-2xl font-bold">Ready to begin?</h2>
          <p class="mx-auto mt-3 max-w-md text-brand-100">{page.ctaSubtext}</p>
          <a
            href="/test"
            class="mt-6 inline-flex rounded-2xl bg-white px-8 py-3.5 text-base font-semibold text-brand-700 shadow-lg transition hover:bg-brand-50"
          >
            {page.ctaLabel}
          </a>
        </div>
        <LandingRelatedLinks current={page.slug} />
      </div>
    </div>
  </article>
</BaseLayout>
