---
import { guidePages } from '../data/guides';
---

<section id="iq-guides" class="section-pad border-t border-slate-200/80 bg-slate-50/50 dark:border-slate-800 dark:bg-slate-900/30" aria-labelledby="guides-heading">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Knowledge hub</p>
      <h2 id="guides-heading" class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        IQ guides written for curious minds
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-600 dark:text-slate-400">
        Original educational articles on scores, accuracy, practice, and more—always with clear limits. Not clinical advice.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {guidePages.map((g) => (
        <a
          href={g.path}
          class="group card-surface flex flex-col p-5 transition hover:border-brand-300 hover:shadow-md dark:hover:border-brand-700"
        >
          <h3 class="font-display text-base font-bold text-slate-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-400">
            {g.label}
          </h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{g.description}</p>
          <span class="mt-4 text-sm font-semibold text-brand-600 dark:text-brand-400">Read guide →</span>
        </a>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/test" class="btn-primary !inline-flex">Take the Free IQ Test</a>
    </div>
  </div>
</section>
