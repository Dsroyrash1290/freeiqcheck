---
import { allSeoArticles, type ArticleSlug } from '../../data/seoArticles';

interface Props {
  current: ArticleSlug;
}
const { current } = Astro.props;
const others = allSeoArticles.filter((a) => a.slug !== current);
---

<aside class="card-surface p-6" aria-label="Related articles">
  <h2 class="font-display text-lg font-bold text-slate-900 dark:text-white">Related articles</h2>
  <ul class="mt-4 space-y-2">
    {others.map((a) => (
      <li>
        <a href={a.path} class="text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">
          {a.linkLabel}
        </a>
      </li>
    ))}
    <li class="border-t border-slate-200 pt-3 dark:border-slate-800">
      <a href="/test" class="text-sm font-semibold text-slate-800 hover:text-brand-600 dark:text-slate-200 dark:hover:text-brand-400">
        Take the free IQ test →
      </a>
    </li>
    <li>
      <a href="/faq" class="text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">FAQ</a>
    </li>
    <li>
      <a href="/about" class="text-sm font-medium text-brand-600 hover:underline dark:text-brand-400">About</a>
    </li>
  </ul>
</aside>
