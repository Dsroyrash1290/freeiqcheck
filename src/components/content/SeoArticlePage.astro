---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../Disclaimer.astro';
import FaqAccordion from '../FaqAccordion.astro';
import SectionHeading from '../SectionHeading.astro';
import GuideRelatedLinks from './GuideRelatedLinks.astro';
import type { SeoArticle } from '../../data/seoArticles';
import { faqJsonLd, webPageJsonLd } from '../../lib/seo';

interface Props {
  article: SeoArticle;
}
const { article } = Astro.props;
---

<BaseLayout
  title={article.title}
  description={article.description}
  path={article.path}
  jsonLd={[webPageJsonLd(article.title, article.description, article.path), faqJsonLd(article.faq)]}
>
  <article itemscope itemtype="https://schema.org/Article">
    <meta itemprop="headline" content={article.h1} />
    <header class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
      <div class="section-pad mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">{article.eyebrow}</p>
        <h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
          {article.h1}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-400" itemprop="description">
          {article.intro}
        </p>
        <a href="/test" class="btn-primary mt-8 !inline-flex">{article.ctaLabel}</a>
        <p class="mt-4 text-xs text-slate-500">Educational content · Not medical advice</p>
      </div>
    </header>

    <div class="section-pad mx-auto max-w-3xl">
      <div class="space-y-14" itemprop="articleBody">
        {article.sections.map((section) => (
          <section>
            <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white">{section.heading}</h2>
            {section.paragraphs?.map((p) => (
              <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
            ))}
            {section.table && (
              <figure class="mt-6 overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800">
                <div class="overflow-x-auto">
                  <table class="w-full min-w-[280px] text-left text-sm">
                    <caption class="bg-slate-50 px-4 py-3 text-left text-xs font-medium text-slate-600 dark:bg-slate-900 dark:text-slate-400">
                      {section.table.caption}
                    </caption>
                    <thead class="border-b border-slate-200 bg-brand-50/80 dark:border-slate-800 dark:bg-brand-950/40">
                      <tr>
                        {section.table.headers.map((h) => (
                          <th scope="col" class="px-4 py-3 font-semibold text-slate-900 dark:text-white">{h}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                      {section.table.rows.map((row) => (
                        <tr class="bg-white dark:bg-slate-900/50">
                          {row.map((cell) => (
                            <td class="px-4 py-3 text-slate-600 dark:text-slate-400">{cell}</td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </figure>
            )}
            {section.subsections?.map((sub) => (
              <div class="mt-8">
                <h3 class="font-display text-xl font-bold text-slate-800 dark:text-slate-200">{sub.heading}</h3>
                {sub.paragraphs.map((p) => (
                  <p class="mt-3 text-base leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
                ))}
              </div>
            ))}
          </section>
        ))}
      </div>

      <p class="mt-12 text-center text-sm text-slate-600 dark:text-slate-400">
        Ready to apply what you learned?
        <a href="/test" class="font-semibold text-brand-600 hover:underline dark:text-brand-400"> Take our free iq test online</a>.
      </p>

      <Disclaimer />

      <section class="mt-14" aria-labelledby={`faq-${article.slug}`}>
        <SectionHeading eyebrow="FAQ" title={article.faqTitle} align="center" />
        <h2 id={`faq-${article.slug}`} class="sr-only">{article.faqTitle}</h2>
        <div class="mt-10">
          <FaqAccordion items={article.faq} />
        </div>
      </section>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2 rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 p-8 text-center text-white lg:p-10">
          <h2 class="font-display text-2xl font-bold">Practice logical reasoning</h2>
          <p class="mx-auto mt-3 max-w-md text-brand-100">{article.ctaSubtext}</p>
          <a
            href="/test"
            class="mt-6 inline-flex rounded-2xl bg-white px-8 py-3.5 text-base font-semibold text-brand-700 shadow-lg transition hover:bg-brand-50"
          >
            {article.ctaLabel}
          </a>
        </div>
        <GuideRelatedLinks current={article.path} />
      </div>
    </div>
  </article>
</BaseLayout>
