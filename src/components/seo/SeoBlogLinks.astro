---
import { blogSeoLinks } from '../../data/seoLinks';

interface Props {
  title?: string;
  class?: string;
}
const { title = 'Related articles', class: className = '' } = Astro.props;
---

<aside class:list={['card-surface p-6', className]} aria-label="Related blog articles">
  <h2 class="font-display text-lg font-bold text-slate-900 dark:text-white">{title}</h2>
  <ul class="mt-4 space-y-3">
    {blogSeoLinks.map((link) => (
      <li>
        <a href={link.href} class="group block rounded-xl border border-transparent p-2 transition hover:border-brand-200 hover:bg-brand-50/50 dark:hover:border-brand-800 dark:hover:bg-brand-950/30">
          <span class="text-sm font-semibold text-brand-600 group-hover:underline dark:text-brand-400">{link.label}</span>
          <span class="mt-0.5 block text-xs text-slate-500 dark:text-slate-400">{link.description}</span>
        </a>
      </li>
    ))}
  </ul>
</aside>
