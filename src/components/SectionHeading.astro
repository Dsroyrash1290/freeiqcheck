---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={[align === 'center' && 'mx-auto max-w-2xl text-center']}>
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">{eyebrow}</p>
  )}
  <h2 class="mt-2 font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">{title}</h2>
  {description && (
    <p class="mt-3 text-lg leading-relaxed text-slate-600 dark:text-slate-400">{description}</p>
  )}
</div>
