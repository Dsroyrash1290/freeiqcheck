---
interface Props {
  href?: string;
  label?: string;
  triggerId?: string;
}
const { href = '/test', label = 'Start Free IQ Test', triggerId = 'hero-heading' } = Astro.props;
---

<a
  href={href}
  id="sticky-quiz-cta"
  class="fixed bottom-6 right-6 z-50 hidden rounded-2xl bg-brand-600 px-5 py-3.5 text-sm font-semibold text-white shadow-xl shadow-brand-600/30 transition motion-safe:hover:scale-105 motion-safe:hover:bg-brand-700 sm:bottom-8 sm:right-8 sm:px-6 sm:text-base"
  aria-label={label}
>
  {label}
</a>

<script define:vars={{ triggerId }}>
  const cta = document.getElementById('sticky-quiz-cta');
  const trigger = document.getElementById(triggerId);

  function toggleCta() {
    if (!cta || !trigger) return;
    const pastHero = window.scrollY > trigger.offsetHeight * 0.5;
    cta.classList.toggle('hidden', !pastHero);
  }

  toggleCta();
  window.addEventListener('scroll', toggleCta, { passive: true });
</script>
