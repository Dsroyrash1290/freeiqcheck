---
import type { BlogPost } from '../../data/blog';
import { formatBlogDate } from '../../lib/blogContent';

interface Props {
  post: BlogPost;
}
const { post } = Astro.props;
const date = formatBlogDate(post.publishedAt);
---

<article class="article-card card-surface flex h-full flex-col overflow-hidden">
  <div class="border-b border-slate-100 bg-gradient-to-br from-brand-50/80 to-slate-50 px-6 py-4 dark:border-slate-800 dark:from-brand-950/30 dark:to-slate-900/50">
    <p class="text-xs font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">{post.readTime}</p>
    <h2 class="mt-2 font-display text-xl font-bold leading-snug text-slate-900 dark:text-white">
      <a href={post.path} class="hover:text-brand-600 dark:hover:text-brand-400">{post.title}</a>
    </h2>
  </div>
  <div class="flex flex-1 flex-col p-6">
    <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">{post.excerpt}</p>
    <p class="mt-4 text-xs text-slate-500">{date}</p>
    <a
      href={post.path}
      class="mt-auto pt-6 text-sm font-semibold text-brand-600 hover:underline dark:text-brand-400"
      aria-label={`Read ${post.title}`}
    >
      Read article →
    </a>
  </div>
</article>
