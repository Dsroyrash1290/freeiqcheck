---
interface TocItem {
  id: string;
  text: string;
}

interface Props {
  items: TocItem[];
}
const { items } = Astro.props;
---

{items.length > 0 && (
  <nav
    id="blog-toc"
    class="blog-toc card-surface mb-10 p-5 lg:sticky lg:top-24 lg:mb-0 lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto lg:p-6"
    aria-label="Table of contents"
  >
    <p class="text-xs font-bold uppercase tracking-wider text-brand-600 dark:text-brand-400">On this page</p>
    <ol class="mt-4 space-y-2">
      {items.map((item) => (
        <li>
          <a
            href={`#${item.id}`}
            data-toc-link={item.id}
            class="toc-link block rounded-lg px-2 py-1.5 text-sm leading-snug text-slate-600 transition hover:bg-brand-50 hover:text-brand-700 dark:text-slate-400 dark:hover:bg-brand-950/40 dark:hover:text-brand-300"
          >
            {item.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  const headings = Array.from(links)
    .map((link) => document.getElementById(link.dataset.tocLink ?? ''))
    .filter((el): el is HTMLElement => Boolean(el));

  if (headings.length && links.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;
          links.forEach((link) => {
            const active = link.dataset.tocLink === id;
            link.classList.toggle('bg-brand-50', active);
            link.classList.toggle('text-brand-700', active);
            link.classList.toggle('font-semibold', active);
            link.classList.toggle('dark:bg-brand-950/50', active);
            link.classList.toggle('dark:text-brand-300', active);
          });
        });
      },
      { rootMargin: '-20% 0px -70% 0px', threshold: 0 },
    );
    headings.forEach((h) => observer.observe(h));
  }
</script>
