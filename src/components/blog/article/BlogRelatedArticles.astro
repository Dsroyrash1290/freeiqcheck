---
import type { BlogRelatedLink } from '../../../data/blog/types';

interface Props {
  links: BlogRelatedLink[];
}
const { links } = Astro.props;
---

<section class="mt-16" aria-labelledby="related-guides-heading">
  <h2 id="related-guides-heading" class="font-display text-2xl font-bold text-slate-900 dark:text-white">
    Related articles
  </h2>
  <div class="mt-6 grid gap-4 sm:grid-cols-2">
    {links.map((link) => (
      <a
        href={link.href}
        class="article-card group block rounded-2xl border border-slate-200/80 bg-white/80 p-5 dark:border-slate-800 dark:bg-slate-900/50"
      >
        <h3 class="font-display text-lg font-bold text-slate-900 transition group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
          {link.title}
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{link.description}</p>
        <span class="mt-3 inline-block text-sm font-semibold text-brand-600 dark:text-brand-400">Read more →</span>
      </a>
    ))}
  </div>
</section>
