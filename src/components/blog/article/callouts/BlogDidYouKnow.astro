---
interface Props {
  text: string;
}
const { text } = Astro.props;
---

<aside class="blog-did-you-know my-8 rounded-2xl border border-violet-200/80 bg-violet-50/70 p-5 dark:border-violet-900/40 dark:bg-violet-950/25 sm:p-6">
  <div class="flex gap-3">
    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-violet-500/15 text-lg" aria-hidden="true">💡</span>
    <div>
      <p class="text-xs font-bold uppercase tracking-wider text-violet-700 dark:text-violet-400">Did You Know?</p>
      <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300 sm:text-base" set:html={text} />
    </div>
  </div>
</aside>
