---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---

<div class="blog-statistics my-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {stats.map((stat) => (
    <div class="stat-card rounded-2xl border border-slate-200/80 bg-white/80 p-5 text-center dark:border-slate-700 dark:bg-slate-900/50">
      <p class="font-display text-3xl font-extrabold text-brand-600 dark:text-brand-400">{stat.value}</p>
      <p class="mt-1 text-sm leading-snug text-slate-600 dark:text-slate-400">{stat.label}</p>
    </div>
  ))}
</div>
