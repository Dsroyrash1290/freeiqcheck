---
interface Props {
  myth: string;
  reality: string;
}
const { myth, reality } = Astro.props;
---

<aside class="blog-myth-reality my-8 overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700">
  <div class="grid sm:grid-cols-2">
    <div class="border-b border-slate-200 bg-rose-50/80 p-5 dark:border-slate-700 dark:bg-rose-950/20 sm:border-b-0 sm:border-r">
      <p class="text-xs font-bold uppercase tracking-wider text-rose-600 dark:text-rose-400">Common Myth</p>
      <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300 sm:text-base">{myth}</p>
    </div>
    <div class="bg-emerald-50/80 p-5 dark:bg-emerald-950/20">
      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 dark:text-emerald-400">Reality</p>
      <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300 sm:text-base">{reality}</p>
    </div>
  </div>
</aside>
