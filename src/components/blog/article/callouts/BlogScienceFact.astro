---
interface Props {
  title: string;
  text: string;
}
const { title, text } = Astro.props;
---

<aside class="blog-science-fact my-8 rounded-2xl border border-emerald-200/80 bg-emerald-50/80 p-5 dark:border-emerald-900/50 dark:bg-emerald-950/30 sm:p-6">
  <div class="flex gap-3">
    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-500/15 text-lg" aria-hidden="true">🔬</span>
    <div>
      <p class="text-xs font-bold uppercase tracking-wider text-emerald-700 dark:text-emerald-400">Science Fact</p>
      <h3 class="mt-1 font-display text-lg font-bold text-slate-900 dark:text-white">{title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300 sm:text-base">{text}</p>
    </div>
  </div>
</aside>
