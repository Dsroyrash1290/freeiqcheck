---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../Disclaimer.astro';
import FaqAccordion from '../FaqAccordion.astro';
import SectionHeading from '../SectionHeading.astro';
import BlogCard from './BlogCard.astro';
import type { BlogPost } from '../../data/blog';
import { getRelatedPosts } from '../../data/blog';
import { blogPostingJsonLd, faqJsonLd } from '../../lib/seo';

interface Props {
  post: BlogPost;
}
const { post } = Astro.props;
const related = getRelatedPosts(post);
const published = new Date(post.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={post.seoTitle}
  description={post.description}
  path={post.path}
  ogType="article"
  jsonLd={[
    blogPostingJsonLd({
      title: post.title,
      description: post.description,
      path: post.path,
      publishedAt: post.publishedAt,
    }),
    faqJsonLd(post.faq),
  ]}
>
  <article itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="headline" content={post.title} />
    <meta itemprop="datePublished" content={post.publishedAt} />
    <header class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
      <div class="section-pad mx-auto max-w-3xl">
        <p class="text-center">
          <a href="/blog" class="text-sm font-semibold text-brand-600 hover:underline dark:text-brand-400">← Blog</a>
        </p>
        <p class="mt-4 text-center text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">
          {post.readTime} · {published}
        </p>
        <h1 class="mt-4 text-center font-display text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
          {post.title}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-center text-lg leading-relaxed text-slate-600 dark:text-slate-400" itemprop="description">
          {post.excerpt}
        </p>
        <div class="mt-8 text-center">
          <a href="/test" class="btn-primary !inline-flex">Take the Free IQ Test</a>
        </div>
      </div>
    </header>

    <div class="section-pad mx-auto max-w-3xl">
      <div class="space-y-14" itemprop="articleBody">
        {post.sections.map((section) => (
          <section>
            <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white">{section.heading}</h2>
            {section.paragraphs?.map((p) => (
              <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
            ))}
            {section.list && (
              <ol class="mt-6 space-y-4">
                {section.list.map((item, i) => (
                  <li class="card-surface p-4">
                    <h3 class="font-display font-bold text-slate-900 dark:text-white">
                      {section.list!.length > 3 && !item.title.match(/^\d+\./) ? `${i + 1}. ` : ''}{item.title}
                    </h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{item.text}</p>
                  </li>
                ))}
              </ol>
            )}
            {section.subsections?.map((sub) => (
              <div class="mt-8">
                <h3 class="font-display text-xl font-bold text-slate-800 dark:text-slate-200">{sub.heading}</h3>
                {sub.paragraphs.map((p) => (
                  <p class="mt-3 text-base leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
                ))}
              </div>
            ))}
          </section>
        ))}
      </div>

      <aside class="mt-12 card-surface p-6" aria-label="Internal links">
        <h2 class="font-display text-lg font-bold text-slate-900 dark:text-white">Explore FreeIQCheck</h2>
        <ul class="mt-3 flex flex-wrap gap-3 text-sm">
          <li><a href="/test" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">Free IQ test</a></li>
          <li><a href="/what-is-iq" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">What is IQ?</a></li>
          <li><a href="/iq-score-chart" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">IQ score chart</a></li>
          <li><a href="/faq" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">FAQ</a></li>
        </ul>
      </aside>

      <Disclaimer />

      <section class="mt-14" aria-labelledby="post-faq">
        <SectionHeading eyebrow="FAQ" title={`${post.title} — FAQ`} align="center" />
        <h2 id="post-faq" class="sr-only">Frequently asked questions</h2>
        <div class="mt-10">
          <FaqAccordion items={post.faq} />
        </div>
      </section>

      {related.length > 0 && (
        <section class="mt-16" aria-labelledby="related-posts">
          <h2 id="related-posts" class="font-display text-2xl font-bold text-slate-900 dark:text-white">Related articles</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => (
              <BlogCard post={r} />
            ))}
          </div>
        </section>
      )}

      <div class="mt-14 rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 p-8 text-center text-white">
        <h2 class="font-display text-2xl font-bold">Put knowledge into practice</h2>
        <p class="mx-auto mt-3 max-w-md text-brand-100">Take our 25-question quiz and get instant illustrative results with explanations.</p>
        <a href="/test" class="mt-6 inline-flex rounded-2xl bg-white px-8 py-3.5 font-semibold text-brand-700 shadow-lg hover:bg-brand-50">
          Start Free IQ Test
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
