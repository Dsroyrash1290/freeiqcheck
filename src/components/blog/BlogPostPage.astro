---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../Disclaimer.astro';
import FaqAccordion from '../FaqAccordion.astro';
import SectionHeading from '../SectionHeading.astro';
import BlogCard from './BlogCard.astro';
import BlogGraphic from './BlogGraphic.astro';
import type { BlogPost } from '../../data/blog';
import { getRelatedPosts } from '../../data/blog';
import { blogPostingJsonLd, breadcrumbJsonLd, faqJsonLd } from '../../lib/seo';
import { formatBlogDate } from '../../lib/blogContent';
import { linkify, slugifyHeading } from '../../lib/linkify';

interface Props {
  post: BlogPost;
}
const { post } = Astro.props;
const related = getRelatedPosts(post);
const published = formatBlogDate(post.publishedAt);
const sectionAnchors = post.sections.map((s) => slugifyHeading(s.heading));
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
  { name: post.title, path: post.path },
];
---

<BaseLayout
  title={post.seoTitle}
  description={post.description}
  path={post.path}
  ogType="article"
  jsonLd={[
    blogPostingJsonLd({
      title: post.title,
      description: post.description,
      path: post.path,
      publishedAt: post.publishedAt,
    }),
    faqJsonLd(post.faq),
    breadcrumbJsonLd(breadcrumbs),
  ]}
>
  <article itemscope itemtype="https://schema.org/BlogPosting">
    <meta itemprop="headline" content={post.title} />
    <meta itemprop="datePublished" content={post.publishedAt} />
    <header class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
      <div class="section-pad mx-auto max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-center">
          <ol class="inline-flex flex-wrap items-center justify-center gap-1 text-sm text-slate-500 dark:text-slate-400">
            <li><a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/blog" class="hover:text-brand-600 dark:hover:text-brand-400">Blog</a></li>
            <li aria-hidden="true">/</li>
            <li class="font-medium text-slate-700 dark:text-slate-300" aria-current="page">{post.title}</li>
          </ol>
        </nav>
        <p class="mt-4 text-center text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">
          {post.readTime} · {published}
        </p>
        <h1 class="mt-4 text-center font-display text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl dark:text-white">
          {post.title}
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-center text-lg leading-relaxed text-slate-600 dark:text-slate-400" itemprop="description">
          {post.excerpt}
        </p>
        <div class="mt-8 text-center">
          <a href="/test" class="btn-primary !inline-flex">Take the Free IQ Test</a>
        </div>
      </div>
    </header>

    <div class="section-pad mx-auto max-w-3xl">
      {post.showToc && (
        <nav aria-label="Table of contents" class="card-surface mb-12 p-6">
          <h2 class="font-display text-lg font-bold text-slate-900 dark:text-white">Table of contents</h2>
          <ol class="mt-4 space-y-2 text-sm">
            {post.sections.map((section, i) => (
              <li>
                <a
                  href={`#${sectionAnchors[i]}`}
                  class="text-brand-600 hover:underline dark:text-brand-400"
                >
                  {section.heading}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <div class="space-y-14" itemprop="articleBody">
        {post.sections.map((section, i) => (
          <section id={sectionAnchors[i]}>
            <h2 class="scroll-mt-24 font-display text-2xl font-bold text-slate-900 dark:text-white">{section.heading}</h2>
            {section.paragraphs?.map((p) => (
              <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400" set:html={linkify(p)} />
            ))}
            {section.list && (
              <ol class="mt-6 space-y-4">
                {section.list.map((item, j) => (
                  <li class="card-surface p-4">
                    <h3 class="font-display font-bold text-slate-900 dark:text-white">
                      {section.list!.length > 3 && !item.title.match(/^\d+\./) ? `${j + 1}. ` : ''}{item.title}
                    </h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400" set:html={linkify(item.text)} />
                  </li>
                ))}
              </ol>
            )}
            {section.subsections?.map((sub) => (
              <div class="mt-8">
                <h3 class="font-display text-xl font-bold text-slate-800 dark:text-slate-200">{sub.heading}</h3>
                {sub.paragraphs.map((p) => (
                  <p class="mt-3 text-base leading-relaxed text-slate-600 dark:text-slate-400" set:html={linkify(p)} />
                ))}
              </div>
            ))}
            {section.graphic && <BlogGraphic id={section.graphic} />}
          </section>
        ))}
      </div>

      {post.authorProfile && (
        <aside class="mt-12 card-surface p-6" aria-label="About the author">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-700 dark:bg-brand-900/50 dark:text-brand-300" aria-hidden="true">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Author</p>
              <p class="mt-1 font-display text-lg font-bold text-slate-900 dark:text-white" itemprop="author">{post.authorProfile.name}</p>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">{post.authorProfile.role}</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{post.authorProfile.bio}</p>
            </div>
          </div>
        </aside>
      )}

      <aside class="mt-12 card-surface p-6" aria-label="Internal links">
        <h2 class="font-display text-lg font-bold text-slate-900 dark:text-white">Explore FreeIQCheck</h2>
        <ul class="mt-3 flex flex-wrap gap-3 text-sm">
          <li><a href="/test" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">Free IQ test</a></li>
          <li><a href="/" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">Homepage</a></li>
          <li><a href="/what-is-iq" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">What is IQ?</a></li>
          <li><a href="/iq-score-chart" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">IQ score chart</a></li>
          <li><a href="/faq" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">FAQ</a></li>
        </ul>
      </aside>

      <Disclaimer />

      <section class="mt-14" aria-labelledby="post-faq">
        <SectionHeading eyebrow="FAQ" title={`${post.title} — FAQ`} align="center" />
        <h2 id="post-faq" class="sr-only">Frequently asked questions</h2>
        <div class="mt-10">
          <FaqAccordion items={post.faq} />
        </div>
      </section>

      {related.length > 0 && (
        <section class="mt-16" aria-labelledby="related-posts">
          <h2 id="related-posts" class="font-display text-2xl font-bold text-slate-900 dark:text-white">Related articles</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((r) => (
              <BlogCard post={r} />
            ))}
          </div>
        </section>
      )}

      <div class="mt-14 rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 p-8 text-center text-white">
        <h2 class="font-display text-2xl font-bold">Put knowledge into practice</h2>
        <p class="mx-auto mt-3 max-w-md text-brand-100">Take our 25-question quiz and get instant illustrative results with explanations.</p>
        <a href="/test" class="mt-6 inline-flex rounded-2xl bg-white px-8 py-3.5 font-semibold text-brand-700 shadow-lg hover:bg-brand-50">
          Start Free IQ Test
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
