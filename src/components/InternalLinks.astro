---
import { guidePages } from '../data/guides';

interface Props {
  title?: string;
  class?: string;
  limit?: number;
}
const { title = 'IQ guides & resources', class: className = '', limit = 8 } = Astro.props;
const links = guidePages.slice(0, limit);
---

<nav class:list={['card-surface p-6', className]} aria-label="Related pages">
  <p class="text-sm font-semibold text-slate-900 dark:text-white">{title}</p>
  <ul class="mt-3 flex flex-wrap gap-3">
    {links.map((link) => (
      <li>
        <a
          href={link.path}
          class="inline-flex rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-brand-300 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-800/50 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
        >
          {link.label}
        </a>
      </li>
    ))}
    <li>
      <a
        href="/test"
        class="inline-flex rounded-xl border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 transition hover:bg-brand-100 dark:border-brand-800 dark:bg-brand-950 dark:text-brand-300"
      >
        Take the quiz →
      </a>
    </li>
  </ul>
</nav>
