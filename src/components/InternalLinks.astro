---
import { seoNavLinks } from '../config/site';

interface Props {
  title?: string;
  class?: string;
}
const { title = 'Explore FreeIQCheck', class: className = '' } = Astro.props;
---

<nav class:list={['card-surface p-6', className]} aria-label="Related pages">
  <p class="text-sm font-semibold text-slate-900 dark:text-white">{title}</p>
  <ul class="mt-3 flex flex-wrap gap-3">
    {seoNavLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class="inline-flex rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-brand-300 hover:text-brand-700 dark:border-slate-700 dark:bg-slate-800/50 dark:text-slate-300 dark:hover:border-brand-600 dark:hover:text-brand-400"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
