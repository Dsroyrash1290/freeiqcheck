---
import { allSeoArticles } from '../data/seoArticles';
import { legalPages } from '../data/legal';
import { allLandingPages } from '../data/landingPages';
import { site } from '../config/site';

const footerLinks = [
  { href: '/test', label: 'Free IQ test' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/faq', label: 'FAQ' },
  { href: '/results', label: 'Results' },
  { href: '/contact', label: 'Contact' },
];
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-950">
  <div class="section-pad mx-auto max-w-6xl !py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-6">
      <div>
        <p class="font-display text-lg font-bold text-slate-900 dark:text-white">{site.name}</p>
        <p class="mt-2 max-w-sm text-sm leading-relaxed text-slate-600 dark:text-slate-400">
          A {site.primaryKeyword} online with instant results for education and entertainment. Not a clinical IQ assessment.
        </p>
      </div>
      <nav aria-label="Footer navigation">
        <p class="text-sm font-semibold text-slate-900 dark:text-white">Explore</p>
        <ul class="mt-3 space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <nav aria-label="SEO guides">
        <p class="text-sm font-semibold text-slate-900 dark:text-white">Guides</p>
        <ul class="mt-3 space-y-2">
          {allLandingPages.map((p) => (
            <li>
              <a href={p.path} class="text-sm text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400">
                {p.linkLabel}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <nav aria-label="IQ education articles">
        <p class="text-sm font-semibold text-slate-900 dark:text-white">Learn</p>
        <ul class="mt-3 space-y-2">
          {allSeoArticles.map((a) => (
            <li>
              <a href={a.path} class="text-sm text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400">
                {a.linkLabel}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <nav aria-label="Legal">
        <p class="text-sm font-semibold text-slate-900 dark:text-white">Legal</p>
        <ul class="mt-3 space-y-2">
          {legalPages.map((page) => (
            <li>
              <a href={page.href} class="text-sm text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400">
                {page.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <div>
        <p class="text-sm font-semibold text-slate-900 dark:text-white">Take the test</p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Free iq test with instant results · No email · 25 questions
        </p>
        <a
          href="/test"
          class="mt-4 inline-flex rounded-xl border border-brand-200 bg-brand-50 px-4 py-2.5 text-sm font-semibold text-brand-700 transition hover:bg-brand-100 dark:border-brand-800 dark:bg-brand-950 dark:text-brand-300"
        >
          Start Free IQ Test
        </a>
      </div>
    </div>
    <div class="mt-10 flex flex-col gap-2 border-t border-slate-200 pt-8 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>{site.domain} — {site.primaryKeyword} for entertainment only.</p>
    </div>
  </div>
</footer>
