---
interface Props {
  title: string;
  subtitle?: string;
  testId?: 'memory' | 'pattern' | 'wordRecall';
  backHref?: string;
}
const { title, subtitle, testId, backHref = '/brain-games' } = Astro.props;
---

<section class="brain-games relative min-h-[70vh] overflow-hidden">
  <div class="brain-games-bg" aria-hidden="true">
    <div class="brain-games-orb brain-games-orb--1"></div>
    <div class="brain-games-orb brain-games-orb--2"></div>
    <div class="brain-games-orb brain-games-orb--3"></div>
    <div class="brain-games-grid"></div>
  </div>

  <div class="section-pad relative mx-auto max-w-3xl">
    <nav class="mb-6">
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-brand-600 transition hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
      >
        <span aria-hidden="true">←</span> Back to Brain Games
      </a>
    </nav>

    <header class="mb-8 text-center motion-safe:animate-fade-up">
      <p class="text-sm font-bold uppercase tracking-wider text-brand-600 dark:text-brand-400">Brain Games</p>
      <h1 class="mt-2 font-display text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        {title}
      </h1>
      {subtitle && (
        <p class="mx-auto mt-3 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">{subtitle}</p>
      )}
    </header>

    <div class="brain-games-glass motion-safe:animate-fade-up" data-brain-games-test={testId}>
      <slot />
    </div>
  </div>
</section>
