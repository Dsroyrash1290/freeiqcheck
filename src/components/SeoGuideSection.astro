---
import type { SeoSection } from '../data/seoSections';

interface Props {
  sections: SeoSection[];
}
const { sections } = Astro.props;
---

<section id="iq-test-guide" class="section-pad border-t border-slate-200/80 bg-white dark:border-slate-800 dark:bg-slate-950" aria-labelledby="guide-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="guide-heading" class="font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      Your guide to free IQ tests online
    </h2>
    <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
      Clear, honest information about how our <a href="/test" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">free iq test online</a> works—written for people comparing
      <a href="/faq" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">free iq tests</a> and looking for
      <strong class="font-medium text-slate-800 dark:text-slate-200">instant results without email</strong>.
    </p>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {sections.map((section) => (
        <article id={section.id} class="card-surface p-6 sm:p-8">
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white">{section.title}</h3>
          {section.paragraphs.map((p) => (
            <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
          ))}
        </article>
      ))}
    </div>
  </div>
</section>
