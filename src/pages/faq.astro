---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { faqItems } from '../data/faq';
import { faqJsonLd, webPageJsonLd } from '../lib/seo';

const title = 'FAQ — Free IQ Test & Online IQ Check Questions';
const description =
  'Answers about our free online iq test: scoring, accuracy, retakes, privacy, and whether FreeIQCheck is a real clinical IQ assessment.';
---

<BaseLayout
  title={title}
  description={description}
  path="/faq"
  jsonLd={[webPageJsonLd(title, description, '/faq'), faqJsonLd(faqItems)]}
>
  <section class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
    <div class="section-pad mx-auto max-w-3xl">
      <SectionHeading
        title="Frequently asked questions"
        description="Everything you need to know about our instant iq test and iq score test results."
        align="center"
      />
    </div>
  </section>
  <section class="section-pad mx-auto max-w-3xl">
    <FaqAccordion items={faqItems} />
    <p class="mt-10 text-center">
      <a href="/test" class="rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-700">Start Free IQ Quiz</a>
    </p>
  </section>
</BaseLayout>
