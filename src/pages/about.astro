---
import PageLayout from '../layouts/PageLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { webPageJsonLd } from '../lib/seo';

const title = 'About FreeIQCheck — Free Online IQ-Style Quiz';
const description =
  'Learn about FreeIQCheck, a free educational logical reasoning quiz. We provide instant iq test results for entertainment—not clinical assessment.';
---

<PageLayout
  title={title}
  description={description}
  path="/about"
  heading="About FreeIQCheck"
  subheading="A trustworthy place to practice logical reasoning online."
  jsonLd={[webPageJsonLd(title, description, '/about')]}
>
  <p>
    FreeIQCheck was built for people searching for a <strong>free iq test</strong> or <strong>online iq test</strong> who want a
    clean, honest experience without aggressive upsells or misleading claims.
  </p>
  <p>
    Our 25-question <strong>logical reasoning test</strong> draws on classic puzzle formats: number sequences, verbal analogies, simple
    logic, and everyday deduction. When you finish, you receive an illustrative score and explanations you can learn from.
  </p>
  <h2>What we are not</h2>
  <p>
    We are not psychologists, clinicians, or a licensed testing organization. Scores on this site are not normed against population
    data and must not be used for medical diagnosis, employment screening, or school placement.
  </p>
  <Disclaimer />
  <h2>Our mission</h2>
  <p>
    We believe brain challenges should be accessible, transparent, and enjoyable. Whether you call it an <strong>iq checker</strong>,
    <strong>brain test online</strong>, or <strong>quick iq test</strong>, the value is in the practice—not a label on your identity.
  </p>
  <p>
    <a href="/test">Take the free quiz →</a>
  </p>
</PageLayout>
