---
import PageLayout from '../layouts/PageLayout.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { site } from '../config/site';
import { webPageJsonLd } from '../lib/seo';

const title = 'Contact FreeIQCheck — Free IQ Test Support';
const description = 'Contact FreeIQCheck about our free iq test online, instant results, privacy, or feedback.';
---

<PageLayout
  title={title}
  description={description}
  path="/contact"
  heading="Contact us"
  subheading="Questions, feedback, or partnership inquiries."
  jsonLd={[webPageJsonLd(title, description, '/contact')]}
>
  <p>
    We read every message and aim to respond within a few business days. For privacy-related requests, include
    &quot;Privacy&quot; in your subject line.
  </p>
  <p>
    Email: <a href={`mailto:${site.email}`}>{site.email}</a>
  </p>
  <h2>Before you write</h2>
  <ul>
    <li>We cannot provide clinical IQ assessments or official certificates.</li>
    <li>For quiz help, see our <a href="/faq">FAQ</a>, <a href="/about">about page</a>, or retake the <a href="/test">free iq test online</a>.</li>
    <li>For legal terms, see <a href="/terms">Terms of Use</a> and <a href="/privacy-policy">Privacy Policy</a>.</li>
    <li>For how scoring works, read <a href="/methodology">our methodology</a>.</li>
  </ul>
  <InternalLinks class="mt-8" limit={6} />
</PageLayout>
