---
import BaseLayout from '../layouts/BaseLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { QUESTION_COUNT, QUIZ_DIFFICULTY_COUNTS, questionBank } from '../data/questions';
import { quizJsonLd, webPageJsonLd } from '../lib/seo';

const title = 'Free IQ Test Online — 25 Questions, Instant Results';
const description =
  'Take a free iq test online with instant results and no email. 25 reasoning questions randomly drawn from our 100+ item bank, with balanced difficulty.';

const bankSize = questionBank.length;
---

<BaseLayout
  title={title}
  description={description}
  path="/test"
  jsonLd={[webPageJsonLd(title, description, '/test'), quizJsonLd()]}
>
  <section class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <p class="text-center text-sm font-medium text-brand-600 dark:text-brand-400">Free iq test with instant results</p>
      <h1 class="mt-2 text-center font-display text-3xl font-bold text-slate-900 dark:text-white">Free IQ Test Online</h1>
      <p class="mt-2 text-center text-slate-600 dark:text-slate-400">
        {QUESTION_COUNT} questions · {bankSize}+ item bank · No email ·
        <a href="/practice-iq-questions" class="font-medium text-brand-600 hover:underline dark:text-brand-400">Practice first</a> ·
        <a href="/methodology" class="font-medium text-brand-600 hover:underline dark:text-brand-400">Methodology</a>
      </p>
    </div>
  </section>

  <section class="section-pad mx-auto max-w-3xl !py-8">
    <Disclaimer compact />

    <div id="quiz-app" class="mt-8">
      <div id="quiz-intro" class="card-surface p-8 text-center motion-safe:animate-fade-up">
        <div class="mx-auto mb-6 flex max-w-md flex-wrap justify-center gap-2 text-xs font-semibold">
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-300">{QUIZ_DIFFICULTY_COUNTS.easy} easy</span>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-amber-800 dark:bg-amber-950 dark:text-amber-300">{QUIZ_DIFFICULTY_COUNTS.medium} medium</span>
          <span class="rounded-full bg-rose-100 px-3 py-1 text-rose-800 dark:bg-rose-950 dark:text-rose-300">{QUIZ_DIFFICULTY_COUNTS.hard} hard</span>
        </div>
        <p class="text-slate-600 dark:text-slate-400">
          Each attempt draws <strong class="font-medium text-slate-800 dark:text-slate-200">{QUESTION_COUNT} random questions</strong> from our
          {bankSize}-item bank—answer choices are shuffled too. Retakes feel different but stay fairly balanced.
        </p>
        <p id="resume-hint" class="mt-3 hidden text-sm font-medium text-brand-600 dark:text-brand-400"></p>
        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <button type="button" id="start-quiz" class="btn-primary">Begin Free IQ Test</button>
          <button type="button" id="restart-quiz" class="hidden rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800">
            Start fresh instead
          </button>
        </div>
      </div>

      <div id="quiz-active" class="hidden" role="form" aria-label="IQ reasoning quiz">
        <div class="mb-6 space-y-3">
          <div class="flex flex-wrap items-center justify-between gap-3 text-sm font-medium text-slate-600 dark:text-slate-400">
            <span id="progress-label">Question 1 of {QUESTION_COUNT}</span>
            <span id="timer" class="rounded-lg bg-slate-100 px-3 py-1 font-mono tabular-nums dark:bg-slate-800" aria-live="polite">0:00</span>
          </div>
          <div
            class="h-2.5 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800"
            role="progressbar"
            aria-valuemin="1"
            aria-valuemax={QUESTION_COUNT}
            aria-valuenow="1"
            id="progress-bar-wrap"
          >
            <div id="progress-bar" class="quiz-progress-fill h-full rounded-full" style="width: 4%"></div>
          </div>
        </div>

        <article id="question-card" class="card-surface quiz-card-enter p-6 sm:p-8">
          <div class="flex flex-wrap items-center gap-2">
            <span id="q-difficulty" class="rounded-lg px-2.5 py-1 text-xs font-bold uppercase tracking-wide"></span>
            <span id="q-category" class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-400"></span>
          </div>
          <p class="mt-4 text-sm font-semibold text-brand-600 dark:text-brand-400" id="q-number">Question 1</p>
          <div id="q-visual" class="mt-4 hidden rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-900/50"></div>
          <h2 class="mt-4 font-display text-xl font-bold leading-snug text-slate-900 sm:text-2xl dark:text-white" id="q-prompt"></h2>
          <fieldset class="mt-6 space-y-3" id="q-options">
            <legend class="sr-only">Choose an answer</legend>
          </fieldset>
          <p id="q-error" class="mt-3 hidden text-sm text-red-600 dark:text-red-400" role="alert">Please select an answer to continue.</p>
          <div class="mt-8 flex justify-between gap-4">
            <button
              type="button"
              id="prev-btn"
              class="rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50 disabled:opacity-40 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
              disabled
            >
              Previous
            </button>
            <button type="button" id="next-btn" class="rounded-xl bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700">
              Next
            </button>
          </div>
        </article>
      </div>
    </div>

    <InternalLinks class="mt-10" title="More from FreeIQCheck" />
  </section>

  <script>
    import { categoryLabels } from '../data/questions/categoryLabels';
    import { getVisualHtml } from '../data/questions/visuals';
    import { computeQuizResult } from '../lib/quizScoring';
    import { selectQuizQuestions } from '../lib/quizSelection';
    import { questionBank } from '../data/questions';
    import {
      clearQuizState,
      createSession,
      loadSession,
      QUIZ_SESSION_KEY,
      saveSession,
      STORAGE_KEY,
      type QuizSession,
    } from '../lib/quizSession';

    const total = 25;

    const intro = document.getElementById('quiz-intro');
    const active = document.getElementById('quiz-active');
    const startBtn = document.getElementById('start-quiz');
    const restartBtn = document.getElementById('restart-quiz');
    const resumeHint = document.getElementById('resume-hint');
    const progressLabel = document.getElementById('progress-label');
    const progressBar = document.getElementById('progress-bar');
    const progressWrap = document.getElementById('progress-bar-wrap');
    const timerEl = document.getElementById('timer');
    const qNumber = document.getElementById('q-number');
    const qPrompt = document.getElementById('q-prompt');
    const qVisual = document.getElementById('q-visual');
    const qOptions = document.getElementById('q-options');
    const qError = document.getElementById('q-error');
    const qDifficulty = document.getElementById('q-difficulty');
    const qCategory = document.getElementById('q-category');
    const questionCard = document.getElementById('question-card');
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;

    const difficultyStyles: Record<string, string> = {
      easy: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-300',
      medium: 'bg-amber-100 text-amber-800 dark:bg-amber-950 dark:text-amber-300',
      hard: 'bg-rose-100 text-rose-800 dark:bg-rose-950 dark:text-rose-300',
    };

    let session: QuizSession | null = null;
    let timerId = 0;

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = s % 60;
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function animateCard() {
      if (!questionCard) return;
      questionCard.classList.remove('quiz-card-enter');
      void questionCard.offsetWidth;
      questionCard.classList.add('quiz-card-enter');
    }

    function persistSession() {
      if (session) saveSession(session);
    }

    function render() {
      if (!session) return;
      const q = session.questions[session.index];
      progressLabel!.textContent = `Question ${session.index + 1} of ${total}`;
      progressBar!.style.width = `${((session.index + 1) / total) * 100}%`;
      progressWrap?.setAttribute('aria-valuenow', String(session.index + 1));
      qNumber!.textContent = `Question ${session.index + 1}`;
      qPrompt!.textContent = q.prompt;
      qDifficulty!.textContent = q.difficulty;
      qDifficulty!.className = `rounded-lg px-2.5 py-1 text-xs font-bold uppercase tracking-wide ${difficultyStyles[q.difficulty]}`;
      qCategory!.textContent = categoryLabels[q.category] || q.category;

      const visual = getVisualHtml(q.visualId);
      if (visual && qVisual) {
        qVisual.innerHTML = visual;
        qVisual.classList.remove('hidden');
      } else if (qVisual) {
        qVisual.innerHTML = '';
        qVisual.classList.add('hidden');
      }

      qOptions!.innerHTML = '';
      q.options.forEach((opt: string, i: number) => {
        const id = `opt-${session!.index}-${i}`;
        const checked = session!.answers[session!.index] === i;
        const label = document.createElement('label');
        label.className = [
          'quiz-option flex cursor-pointer items-center gap-3 rounded-xl border px-4 py-3.5 transition',
          checked
            ? 'border-brand-500 bg-brand-50 ring-2 ring-brand-500/20 dark:border-brand-500 dark:bg-brand-950/50'
            : 'border-slate-200 hover:border-brand-300 hover:bg-slate-50 dark:border-slate-700 dark:hover:border-brand-700 dark:hover:bg-slate-800/50',
        ].join(' ');
        label.innerHTML = `<input type="radio" name="answer" id="${id}" value="${i}" class="h-4 w-4 border-slate-300 text-brand-600 focus:ring-brand-500" ${checked ? 'checked' : ''} /><span class="text-sm font-medium text-slate-800 dark:text-slate-200">${opt}</span>`;
        label.querySelector('input')?.addEventListener('change', () => {
          qError?.classList.add('hidden');
          session!.answers[session!.index] = i;
          persistSession();
          render();
        });
        qOptions!.appendChild(label);
      });
      prevBtn.disabled = session.index === 0;
      nextBtn.textContent = session.index === total - 1 ? 'See Results' : 'Next';
      qError?.classList.add('hidden');
      animateCard();
    }

    function getSelected() {
      const checked = qOptions?.querySelector('input[name="answer"]:checked') as HTMLInputElement | null;
      return checked ? Number(checked.value) : -1;
    }

    function startTimer() {
      clearInterval(timerId);
      timerId = window.setInterval(() => {
        if (!session) return;
        session.seconds++;
        timerEl!.textContent = formatTime(session.seconds);
        persistSession();
      }, 1000);
    }

    function showQuiz() {
      intro?.classList.add('hidden');
      active?.classList.remove('hidden');
      timerEl!.textContent = formatTime(session?.seconds ?? 0);
      startTimer();
      render();
    }

    function beginNewQuiz() {
      clearQuizState();
      const selected = selectQuizQuestions(questionBank);
      session = createSession(selected);
      saveSession(session);
      showQuiz();
    }

    function resumeQuiz(existing: QuizSession) {
      session = existing;
      showQuiz();
    }

    function finish() {
      if (!session) return;
      clearInterval(timerId);
      const result = computeQuizResult(session.questions, session.answers, session.seconds);
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(result));
      sessionStorage.removeItem(QUIZ_SESSION_KEY);
      window.location.href = '/results';
    }

    const existing = loadSession();
    if (existing) {
      const answered = existing.answers.filter((a) => a >= 0).length;
      resumeHint!.textContent = `You have an in-progress quiz (${answered}/${total} answered).`;
      resumeHint!.classList.remove('hidden');
      startBtn!.textContent = 'Resume Quiz';
      restartBtn?.classList.remove('hidden');
      restartBtn?.addEventListener('click', beginNewQuiz);
      startBtn?.addEventListener('click', () => resumeQuiz(existing));
    } else {
      startBtn?.addEventListener('click', beginNewQuiz);
    }

    prevBtn?.addEventListener('click', () => {
      if (!session) return;
      const sel = getSelected();
      if (sel >= 0) session.answers[session.index] = sel;
      if (session.index > 0) {
        session.index--;
        persistSession();
        render();
      }
    });

    nextBtn?.addEventListener('click', () => {
      if (!session) return;
      const sel = getSelected();
      if (sel < 0) {
        qError?.classList.remove('hidden');
        return;
      }
      session.answers[session.index] = sel;
      persistSession();
      if (session.index < total - 1) {
        session.index++;
        persistSession();
        render();
      } else {
        finish();
      }
    });

    window.addEventListener('beforeunload', persistSession);
  </script>
</BaseLayout>
