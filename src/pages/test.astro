---
import BaseLayout from '../layouts/BaseLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import InternalLinks from '../components/InternalLinks.astro';
import { QUESTION_COUNT, questions } from '../data/questions';
import { quizJsonLd, webPageJsonLd } from '../lib/seo';

const title = 'Free IQ Test Online — 25 Questions, Instant Results';
const description =
  'Take a free iq test online with instant results and no email. 25 reasoning questions, scaled difficulty, and a free iq test with results when you finish.';

const questionsJson = JSON.stringify(
  questions.map((q) => ({
    id: q.id,
    prompt: q.prompt,
    options: q.options,
    correctIndex: q.correctIndex,
    explanation: q.explanation,
    difficulty: q.difficulty,
    category: q.category,
  })),
);
---

<BaseLayout
  title={title}
  description={description}
  path="/test"
  jsonLd={[webPageJsonLd(title, description, '/test'), quizJsonLd()]}
>
  <section class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <p class="text-center text-sm font-medium text-brand-600 dark:text-brand-400">Free iq test with instant results</p>
      <h1 class="mt-2 text-center font-display text-3xl font-bold text-slate-900 dark:text-white">Free IQ Test Online</h1>
      <p class="mt-2 text-center text-slate-600 dark:text-slate-400">
        {QUESTION_COUNT} questions · No email · <a href="/results" class="font-medium text-brand-600 hover:underline dark:text-brand-400">View sample results</a>
      </p>
    </div>
  </section>

  <section class="section-pad mx-auto max-w-3xl !py-8">
    <Disclaimer compact />

    <div id="quiz-app" class="mt-8">
      <div id="quiz-intro" class="card-surface p-8 text-center motion-safe:animate-fade-up">
        <div class="mx-auto mb-6 flex max-w-sm flex-wrap justify-center gap-2 text-xs font-semibold">
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-300">Easy 1–8</span>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-amber-800 dark:bg-amber-950 dark:text-amber-300">Medium 9–17</span>
          <span class="rounded-full bg-rose-100 px-3 py-1 text-rose-800 dark:bg-rose-950 dark:text-rose-300">Hard 18–25</span>
        </div>
        <p class="text-slate-600 dark:text-slate-400">
          This is a <strong class="font-medium text-slate-800 dark:text-slate-200">free iq test with free results</strong>—questions grow harder as you progress.
          Answer each item before continuing. Your timer starts when you begin; scores appear on our
          <a href="/results" class="font-semibold text-brand-600 hover:underline dark:text-brand-400">results page</a>.
        </p>
        <button type="button" id="start-quiz" class="btn-primary mt-6">Begin Free IQ Test</button>
      </div>

      <div id="quiz-active" class="hidden" role="form" aria-label="IQ reasoning quiz">
        <div class="mb-6 space-y-3">
          <div class="flex flex-wrap items-center justify-between gap-3 text-sm font-medium text-slate-600 dark:text-slate-400">
            <span id="progress-label">Question 1 of {QUESTION_COUNT}</span>
            <span id="timer" class="rounded-lg bg-slate-100 px-3 py-1 font-mono tabular-nums dark:bg-slate-800" aria-live="polite">0:00</span>
          </div>
          <div
            class="h-2.5 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800"
            role="progressbar"
            aria-valuemin="1"
            aria-valuemax={QUESTION_COUNT}
            aria-valuenow="1"
            id="progress-bar-wrap"
          >
            <div id="progress-bar" class="quiz-progress-fill h-full rounded-full" style="width: 4%"></div>
          </div>
          <div class="flex gap-1" aria-hidden="true">
            <span class="h-1 flex-[8] rounded-full bg-emerald-400/60" title="Easy section"></span>
            <span class="h-1 flex-[9] rounded-full bg-amber-400/60" title="Medium section"></span>
            <span class="h-1 flex-[8] rounded-full bg-rose-400/60" title="Hard section"></span>
          </div>
        </div>

        <article id="question-card" class="card-surface quiz-card-enter p-6 sm:p-8">
          <div class="flex flex-wrap items-center gap-2">
            <span id="q-difficulty" class="rounded-lg px-2.5 py-1 text-xs font-bold uppercase tracking-wide"></span>
            <span id="q-category" class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-400"></span>
          </div>
          <p class="mt-4 text-sm font-semibold text-brand-600 dark:text-brand-400" id="q-number">Question 1</p>
          <h2 class="mt-2 font-display text-xl font-bold leading-snug text-slate-900 sm:text-2xl dark:text-white" id="q-prompt"></h2>
          <fieldset class="mt-6 space-y-3" id="q-options">
            <legend class="sr-only">Choose an answer</legend>
          </fieldset>
          <p id="q-error" class="mt-3 hidden text-sm text-red-600 dark:text-red-400" role="alert">Please select an answer to continue.</p>
          <div class="mt-8 flex justify-between gap-4">
            <button
              type="button"
              id="prev-btn"
              class="rounded-xl border border-slate-200 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50 disabled:opacity-40 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
              disabled
            >
              Previous
            </button>
            <button type="button" id="next-btn" class="rounded-xl bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700">
              Next
            </button>
          </div>
        </article>
      </div>
    </div>

    <InternalLinks class="mt-10" title="More from FreeIQCheck" />
  </section>

  <script id="quiz-data" type="application/json" set:html={questionsJson}></script>

  <script>
    import { computeQuizResult, STORAGE_KEY } from '../lib/quizScoring';

    const dataEl = document.getElementById('quiz-data');
    const questions = JSON.parse(dataEl?.textContent || '[]');
    const total = questions.length;

    const intro = document.getElementById('quiz-intro');
    const active = document.getElementById('quiz-active');
    const startBtn = document.getElementById('start-quiz');
    const progressLabel = document.getElementById('progress-label');
    const progressBar = document.getElementById('progress-bar');
    const progressWrap = document.getElementById('progress-bar-wrap');
    const timerEl = document.getElementById('timer');
    const qNumber = document.getElementById('q-number');
    const qPrompt = document.getElementById('q-prompt');
    const qOptions = document.getElementById('q-options');
    const qError = document.getElementById('q-error');
    const qDifficulty = document.getElementById('q-difficulty');
    const qCategory = document.getElementById('q-category');
    const questionCard = document.getElementById('question-card');
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;

    const difficultyStyles: Record<string, string> = {
      easy: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-300',
      medium: 'bg-amber-100 text-amber-800 dark:bg-amber-950 dark:text-amber-300',
      hard: 'bg-rose-100 text-rose-800 dark:bg-rose-950 dark:text-rose-300',
    };

    const categoryLabels: Record<string, string> = {
      pattern: 'Pattern recognition',
      sequence: 'Sequences',
      logic: 'Logic puzzles',
      spatial: 'Spatial reasoning',
      deduction: 'Deduction',
      numerical: 'Numerical reasoning',
      analogy: 'Analogies',
    };

    let index = 0;
    const answers = new Array(total).fill(-1);
    let seconds = 0;
    let timerId = 0;

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = s % 60;
      return `${m}:${sec.toString().padStart(2, '0')}`;
    }

    function animateCard() {
      if (!questionCard) return;
      questionCard.classList.remove('quiz-card-enter');
      void questionCard.offsetWidth;
      questionCard.classList.add('quiz-card-enter');
    }

    function render() {
      const q = questions[index];
      progressLabel!.textContent = `Question ${index + 1} of ${total}`;
      progressBar!.style.width = `${((index + 1) / total) * 100}%`;
      progressWrap?.setAttribute('aria-valuenow', String(index + 1));
      qNumber!.textContent = `Question ${q.id}`;
      qPrompt!.textContent = q.prompt;
      qDifficulty!.textContent = q.difficulty;
      qDifficulty!.className = `rounded-lg px-2.5 py-1 text-xs font-bold uppercase tracking-wide ${difficultyStyles[q.difficulty]}`;
      qCategory!.textContent = categoryLabels[q.category] || q.category;
      qOptions!.innerHTML = '';
      q.options.forEach((opt: string, i: number) => {
        const id = `opt-${index}-${i}`;
        const checked = answers[index] === i;
        const label = document.createElement('label');
        label.className = [
          'quiz-option flex cursor-pointer items-center gap-3 rounded-xl border px-4 py-3.5 transition',
          checked
            ? 'border-brand-500 bg-brand-50 ring-2 ring-brand-500/20 dark:border-brand-500 dark:bg-brand-950/50'
            : 'border-slate-200 hover:border-brand-300 hover:bg-slate-50 dark:border-slate-700 dark:hover:border-brand-700 dark:hover:bg-slate-800/50',
        ].join(' ');
        label.innerHTML = `<input type="radio" name="answer" id="${id}" value="${i}" class="h-4 w-4 border-slate-300 text-brand-600 focus:ring-brand-500" ${checked ? 'checked' : ''} /><span class="text-sm font-medium text-slate-800 dark:text-slate-200">${opt}</span>`;
        label.querySelector('input')?.addEventListener('change', () => {
          qError?.classList.add('hidden');
          answers[index] = i;
          render();
        });
        qOptions!.appendChild(label);
      });
      prevBtn.disabled = index === 0;
      nextBtn.textContent = index === total - 1 ? 'See Results' : 'Next';
      qError?.classList.add('hidden');
      animateCard();
    }

    function getSelected() {
      const checked = qOptions?.querySelector('input[name="answer"]:checked') as HTMLInputElement | null;
      return checked ? Number(checked.value) : -1;
    }

    function finish() {
      clearInterval(timerId);
      const result = computeQuizResult(questions, answers, seconds);
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(result));
      window.location.href = '/results';
    }

    startBtn?.addEventListener('click', () => {
      intro?.classList.add('hidden');
      active?.classList.remove('hidden');
      timerId = window.setInterval(() => {
        seconds++;
        timerEl!.textContent = formatTime(seconds);
      }, 1000);
      render();
    });

    prevBtn?.addEventListener('click', () => {
      const sel = getSelected();
      if (sel >= 0) answers[index] = sel;
      if (index > 0) {
        index--;
        render();
      }
    });

    nextBtn?.addEventListener('click', () => {
      const sel = getSelected();
      if (sel < 0) {
        qError?.classList.remove('hidden');
        return;
      }
      answers[index] = sel;
      if (index < total - 1) {
        index++;
        render();
      } else {
        finish();
      }
    });
  </script>
</BaseLayout>
