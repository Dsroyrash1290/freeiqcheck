---
import BaseLayout from './BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  heading: string;
  subheading?: string;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, path, heading, subheading, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} path={path} jsonLd={jsonLd}>
  <section class="hero-glow border-b border-slate-200/80 dark:border-slate-800">
    <div class="section-pad mx-auto max-w-3xl">
      <SectionHeading title={heading} description={subheading} align="center" />
    </div>
  </section>
  <section class="section-pad mx-auto max-w-3xl">
    <div class="page-content space-y-4 text-slate-600 leading-relaxed dark:text-slate-400 [&_h2]:mt-10 [&_h2]:font-display [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-slate-900 dark:[&_h2]:text-white [&_a]:font-medium [&_a]:text-brand-600 [&_a]:underline-offset-2 hover:[&_a]:underline dark:[&_a]:text-brand-400 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-5 [&_strong]:font-medium [&_strong]:text-slate-800 dark:[&_strong]:text-slate-200">
      <slot />
    </div>
  </section>
</BaseLayout>
